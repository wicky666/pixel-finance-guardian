# ========== Web（Next.js，根目录）==========
# 可选：指向 Nest 后端的根 URL（不要末尾斜杠）。不填则全部数据只在浏览器本地。
NEXT_PUBLIC_API_BASE_URL=http://localhost:3100

# 可选：Supabase（未接业务时可留空）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ========== API（Nest，apps/api）==========
API_PORT=3100
# 逗号分隔，允许的前端来源；不填则开发环境允许全部来源
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# 后续接阿里云 RDS 时填写（当前可不填，使用内存存储）
DATABASE_URL=

# Auth（Phase 5：PostgreSQL 持久化）
AUTH_SECRET=replace-with-long-random-secret
SESSION_COOKIE_NAME=pfg_session
AUTH_SESSION_TTL_HOURS=168
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
DB_SSL=false
DB_POOL_MAX=10

# 后续 Redis / OSS（占位，可配置）
REDIS_URL=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ========== Admin（Vite，apps/admin）==========
# 生产构建时填完整 API 根地址；本地 dev 可留空走 Vite 代理 /api
VITE_API_BASE_URL=
